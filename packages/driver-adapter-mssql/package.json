{
  "name": "@ashiba/driver-adapter-mssql",
  "version": "0.0.0",
  "description": "Thin Ashiba adapter for mssql clients.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ashiba/driver-adapter-core": "workspace:*"
  },
  "peerDependencies": {
    "mssql": ">=11"
  },
  "peerDependenciesMeta": {
    "mssql": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/mssql": "^9.1.8",
    "mssql": "^11.0.1",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
