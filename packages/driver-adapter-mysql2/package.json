{
  "name": "@ashiba/driver-adapter-mysql2",
  "version": "0.0.0",
  "description": "Thin Ashiba adapter for mysql2 clients.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @ashiba/driver-adapter-core build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ashiba/driver-adapter-core": "workspace:*"
  },
  "peerDependencies": {
    "mysql2": ">=3"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "mysql2": "^3.15.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
