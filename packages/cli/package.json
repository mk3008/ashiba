{
  "name": "@ashiba/cli",
  "version": "0.0.0",
  "description": "Ashiba Runtime Zero SQL scaffolder for TypeScript applications.",
  "type": "module",
  "bin": {
    "ashiba": "dist/index.js",
    "ashiba-config": "dist/config-bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "diff": "^8.0.2",
    "rawsql-ts": "^0.21.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
